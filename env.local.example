# Copy this file to .env.local and fill in the values
# Never commit .env.local to git

# MongoDB connection string (required in production)
# For local dev, leave empty to use the automatic in-memory fallback
MONGODB_URI=

# NextAuth.js (REQUIRED — app will crash without these)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-replace-this
NEXTAUTH_URL=http://localhost:3000

# In production, set NEXTAUTH_URL to your actual domain:
# NEXTAUTH_URL=https://yourdomain.com
